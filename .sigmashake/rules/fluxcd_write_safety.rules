# fluxcd_write_safety.rules
# Technology: fluxcd | Capability: write

rule fluxcd-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "kustomization"
  MESSAGE "Blocked an unsafe pattern in fluxcd. Use the recommended best practices for 2025/2026."
}

rule fluxcd-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "fluxctl"
  MESSAGE "You are using an outdated API for fluxcd. Please upgrade to the newer API."
}
